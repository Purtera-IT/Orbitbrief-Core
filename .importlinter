[importlinter]
root_packages =
    orbitbrief_core
include_external_packages = True

# ---------------------------------------------------------------------------
# Phase 0 — parser-os ↔ OrbitBrief seam
# ---------------------------------------------------------------------------
# OrbitBrief consumes the orbitbrief.input.v2 envelope from parser-os.
# The runtime spine and any new modules MUST NOT pull raw PDF/OCR libs
# directly — they must read what parser-os already produced.
#
# Phase 0 baseline: the legacy ``orbitbrief_core.parser.*`` subtree (an
# older inline parser stack that predates the parser-os seam) is pinned
# in ``ignore_imports`` below. Phase 1+ work is to delete it in favour
# of consuming the envelope.
#
# Parser-os internals (``app.parsers.*``, ``app.segmentation.*``) are
# enforced separately by ``tools/check_no_raw_open.py`` because
# import-linter cannot forbid subpackages of external packages.

[importlinter:contract:no-direct-pdf-libs]
name = OrbitBrief must not pull raw PDF/OCR libraries (use parser-os envelope)
type = forbidden
source_modules =
    orbitbrief_core
forbidden_modules =
    pypdfium2
    pdfminer
    pdfplumber
    pymupdf
    fitz
    pytesseract
ignore_imports =
    # ---- Phase-0 baseline: legacy inline-parser subtree ------------------
    # These modules predate the parser-os seam and will be removed in
    # Phase 1 once OrbitBrief consumes the envelope. Do NOT add new
    # entries here — migrate the caller instead.
    orbitbrief_core.parser.adapters.pdf_common -> pdfplumber
    orbitbrief_core.parser.adapters.pdf_common -> fitz
    orbitbrief_core.parser.adapters.providers.paddleocr_vl_provider -> fitz
    orbitbrief_core.parser.adapters.providers.pp_structure_provider -> fitz
    orbitbrief_core.parser.adapters.providers.tesseract_provider -> fitz
    orbitbrief_core.parser.adapters.providers.tesseract_provider -> pytesseract
    orbitbrief_core.parser.site_schematic.core -> fitz
    orbitbrief_core.parser.site_schematic.layout_sections -> fitz
    orbitbrief_core.parser.site_schematic.layout_sections -> pytesseract
    orbitbrief_core.parser.site_schematic.observations -> fitz
    orbitbrief_core.parser.site_schematic.symbols.export -> fitz
