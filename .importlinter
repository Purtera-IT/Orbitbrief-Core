[importlinter]
root_packages =
    orbitbrief_core
include_external_packages = True

# ---------------------------------------------------------------------------
# Phase 0 — parser-os ↔ OrbitBrief seam
# ---------------------------------------------------------------------------
# OrbitBrief consumes the orbitbrief.input.v2 envelope from parser-os.
# Nothing in orbitbrief_core may pull raw PDF/OCR libs directly — read
# what parser-os already produced.
#
# The Phase-0 ignore_imports list (legacy ``orbitbrief_core.parser.*``)
# is GONE as of Phase 1: that subtree was deleted from main and lives
# on the ``legacy_parser_runtime`` git branch for archaeology only.
#
# Parser-os internals (``app.parsers.*``, ``app.segmentation.*``) are
# enforced separately by ``tools/check_no_raw_open.py`` because
# import-linter cannot forbid subpackages of external packages.

[importlinter:contract:no-direct-pdf-libs]
name = OrbitBrief must not pull raw PDF/OCR libraries (use parser-os envelope)
type = forbidden
source_modules =
    orbitbrief_core
forbidden_modules =
    pypdfium2
    pdfminer
    pdfplumber
    pymupdf
    fitz
    pytesseract

# ---------------------------------------------------------------------------
# Phase 2 — Layer-skip prevention
# ---------------------------------------------------------------------------
# composer/, brains/, validator/, calibrator/ MUST NOT import retrieval
# directly. They consume orchestrator-prepared retrieval results, never
# reach into the index themselves. This keeps the retrieval surface
# bounded (RetrievalHit only — no text bodies leaking into prompts) and
# keeps the layered architecture honest.

[importlinter:contract:no-retrieval-bypass]
name = composer / brains / validator / calibrator must not import retrieval directly
type = forbidden
source_modules =
    orbitbrief_core.composer
    orbitbrief_core.brains
    orbitbrief_core.validator
    orbitbrief_core.calibrator
forbidden_modules =
    orbitbrief_core.retrieval

# ---------------------------------------------------------------------------
# Phase 2 — Inference chokepoint
# ---------------------------------------------------------------------------
# All outbound LLM/embedding traffic funnels through
# orbitbrief_core.inference.*. evidence_runtime is a no-LLM zone (Phase
# 1 invariant) and stays that way under static lint too.

[importlinter:contract:evidence-runtime-no-inference]
name = evidence_runtime must not import the inference layer
type = forbidden
source_modules =
    orbitbrief_core.evidence_runtime
forbidden_modules =
    orbitbrief_core.inference
    orbitbrief_core.retrieval

# ---------------------------------------------------------------------------
# Phase 3 — World model layering
# ---------------------------------------------------------------------------
# world_model consumes evidence_runtime + inference (chat client). It MUST
# NOT depend on retrieval (Phase 2 outputs feed downstream brains/composers,
# not the world model). It MUST NOT depend on yet-to-be-built composers /
# brains / validator / calibrator either.
#
# Conversely: evidence_runtime + retrieval + seam may not depend on
# world_model (no upward references from substrate to engines).

[importlinter:contract:world-model-bounded]
name = world_model may consume evidence_runtime + inference, nothing else above
type = forbidden
source_modules =
    orbitbrief_core.world_model
forbidden_modules =
    orbitbrief_core.retrieval
    orbitbrief_core.composers
    orbitbrief_core.brains
    orbitbrief_core.validator
    orbitbrief_core.calibrator

[importlinter:contract:substrate-no-world-model]
name = evidence_runtime / retrieval / seam must not depend on world_model
type = forbidden
source_modules =
    orbitbrief_core.evidence_runtime
    orbitbrief_core.retrieval
    orbitbrief_core.seam
forbidden_modules =
    orbitbrief_core.world_model

# ---------------------------------------------------------------------------
# Phase 5 — Brains layer isolation
# ---------------------------------------------------------------------------
# Brains synthesize domain-specific findings from BriefState (Phase 4) plus a
# typed RetrievalBundle that the orchestrator pre-assembles. A brain MUST
# NEVER read raw envelopes, walk the runtime, hit the seam loader, or call the
# retrieval store. Everything it needs flows through the typed inputs.
#
# Brains MAY import:
#   * orbitbrief_core.world_model.planner.schema  (BriefState shape)
#   * orbitbrief_core.inference                   (chat client)
#   * orbitbrief_core.brains._retrieval_bundle    (the typed bundle)

[importlinter:contract:brains-no-substrate]
name = brains must not import the runtime, seam, retrieval store, or world_model engines
type = forbidden
source_modules =
    orbitbrief_core.brains
forbidden_modules =
    orbitbrief_core.evidence_runtime
    orbitbrief_core.seam
    orbitbrief_core.retrieval
    orbitbrief_core.world_model.pack_prior
    orbitbrief_core.world_model.site_reality
    orbitbrief_core.world_model.refiner
    orbitbrief_core.world_model.planner.runner

# Substrate stays oblivious to brains too — no upward imports.

[importlinter:contract:substrate-no-brains]
name = evidence_runtime / retrieval / seam / world_model must not depend on brains
type = forbidden
source_modules =
    orbitbrief_core.evidence_runtime
    orbitbrief_core.retrieval
    orbitbrief_core.seam
    orbitbrief_core.world_model
forbidden_modules =
    orbitbrief_core.brains

# ---------------------------------------------------------------------------
# Phase 6 — Trust layer: validator + calibrator + review_runtime
# ---------------------------------------------------------------------------
# The validator owns path-legality (claim → packet → atom → source_ref) so it
# IS allowed to talk to the runtime via the typed EvidenceLookup adapter.
# It must NOT touch retrieval (retrieval results arrive pre-bundled).
#
# The calibrator runs over validator output + brain output + retrieval bundle.
# It must NOT touch the runtime, the seam, or the retrieval store directly —
# all signals come from typed inputs.
#
# The review_runtime is purely persistence + decision logging. It must NOT
# touch the runtime, the seam, the retrieval store, the world_model engines,
# or the brains layer (it consumes CalibratedItem, not brain state).

[importlinter:contract:calibrator-no-substrate]
name = calibrator must not import the runtime, seam, or retrieval store
type = forbidden
source_modules =
    orbitbrief_core.calibrator
forbidden_modules =
    orbitbrief_core.evidence_runtime
    orbitbrief_core.seam
    orbitbrief_core.retrieval

[importlinter:contract:validator-no-retrieval]
name = validator must not import the retrieval store directly
type = forbidden
source_modules =
    orbitbrief_core.validator
forbidden_modules =
    orbitbrief_core.retrieval

# ---------------------------------------------------------------------------
# Phase 8 — Composer + reviewer UI
# ---------------------------------------------------------------------------
# composer aggregates brain outputs + calibrator + validator into a
# typed ComposedBrief. It must NOT touch the runtime, the seam, the
# retrieval store, or any brain runner. It MAY import brain SCHEMAS
# (BriefingState, ManagedServicesScopeState) since the doc carries
# their payloads through verbatim.
#
# review_ui depends on composer (for the read-only doc render) and
# review_runtime (for queue + decision logging). It must NOT touch
# substrate or world_model engines.

[importlinter:contract:composer-no-substrate]
name = composer must not import the runtime, seam, retrieval, or brain runners
type = forbidden
source_modules =
    orbitbrief_core.composer
forbidden_modules =
    orbitbrief_core.evidence_runtime
    orbitbrief_core.seam
    orbitbrief_core.retrieval
    orbitbrief_core.brains.managed_services.runner
    orbitbrief_core.brains.managed_services.prompt
    orbitbrief_core.brains._briefing_runner
    orbitbrief_core.world_model.pack_prior
    orbitbrief_core.world_model.site_reality
    orbitbrief_core.world_model.refiner
    orbitbrief_core.world_model.planner.runner

[importlinter:contract:review-ui-isolated]
name = review_ui must not import substrate / world_model engines / brain runners
type = forbidden
source_modules =
    orbitbrief_core.review_ui
forbidden_modules =
    orbitbrief_core.evidence_runtime
    orbitbrief_core.seam
    orbitbrief_core.retrieval
    orbitbrief_core.brains.managed_services.runner
    orbitbrief_core.brains.managed_services.prompt
    orbitbrief_core.brains._briefing_runner
    orbitbrief_core.world_model.pack_prior
    orbitbrief_core.world_model.site_reality
    orbitbrief_core.world_model.refiner
    orbitbrief_core.world_model.planner.runner

[importlinter:contract:review-runtime-isolated]
name = review_runtime must not import substrate / world_model engines / brain runners
type = forbidden
source_modules =
    orbitbrief_core.review_runtime
forbidden_modules =
    orbitbrief_core.evidence_runtime
    orbitbrief_core.seam
    orbitbrief_core.retrieval
    orbitbrief_core.world_model.pack_prior
    orbitbrief_core.world_model.site_reality
    orbitbrief_core.world_model.refiner
    orbitbrief_core.world_model.planner.runner
    orbitbrief_core.brains.managed_services.runner
    orbitbrief_core.brains.managed_services.prompt
# review_runtime DOES depend transitively on brain SCHEMAS through the
# calibrator's CalibratedItem (which embeds the brain's payload dict). That's
# expected — the queue carries those payloads through to reviewers verbatim.
# We forbid only the brain runners + prompts, which review_runtime would
# never legitimately need.
