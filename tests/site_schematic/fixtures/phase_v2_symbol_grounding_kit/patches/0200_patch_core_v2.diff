 from orbitbrief_core.parser.site_schematic.reasoning import build_bounded_graph_reasoning, build_reasoning_summaries
+from orbitbrief_core.parser.site_schematic.symbol_candidate_grouping import group_symbol_candidates_from_primitives
+from orbitbrief_core.parser.site_schematic.semantic_mapper import build_legend_grounding_dictionary
+from orbitbrief_core.parser.site_schematic.grounding_resolver import resolve_grounded_symbols
@@
 def build_site_schematic_bundle_from_router_input(
@@
+    # Phase V2 starter
+    v2_candidate_rows = []
+    v2_grounded_rows = []
+    for page_index, obs in enumerate(page_observations):
+        validated_prims = getattr(obs, "validated_vector_primitives", []) or []
+        if not validated_prims:
+            continue
+        text_hints = []
+        if page_index < len(page_texts):
+            text_hints = [tok for tok in page_texts[page_index].split()[:20] if tok]
+        candidates = group_symbol_candidates_from_primitives(
+            page_index=page_index,
+            vector_primitives=validated_prims,
+            nearby_text_hints=text_hints,
+        )
+        page_legend_entries = []
+        try:
+            page_legend_entries = [e for e in legend_entries if getattr(e, "page_index", page_index) == page_index]
+        except Exception:
+            page_legend_entries = []
+        legend_dict = build_legend_grounding_dictionary(page_index=page_index, legend_entries=page_legend_entries)
+        grounded = resolve_grounded_symbols(candidates=candidates, legend_dictionary=legend_dict)
+        v2_candidate_rows.extend(candidates)
+        v2_grounded_rows.extend(grounded)
+    model_registry.setdefault("phase_v2", {})["candidate_symbol_count"] = len(v2_candidate_rows)
+    model_registry["phase_v2"]["grounded_symbol_count"] = len(v2_grounded_rows)
