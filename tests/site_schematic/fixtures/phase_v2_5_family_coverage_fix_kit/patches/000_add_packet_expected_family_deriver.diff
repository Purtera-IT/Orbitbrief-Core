--- /dev/null
+++ b/src/orbitbrief_core/parser/site_schematic/packet_expected_family_deriver.py
@@
+from __future__ import annotations
+
+import re
+from typing import Dict, Iterable, List, Set
+
+
+KEYWORD_TO_FAMILY = {
+    "wireless access point": "wireless_access_point",
+    "wap": "wireless_access_point",
+    "ap": "wireless_access_point",
+    "data outlet": "telecom_data_outlet",
+    "voice outlet": "telecom_voice_outlet",
+    "av": "av_device_outlet",
+    "patch panel": "patch_panel_row",
+    "equipment rack": "equipment_rack_front",
+    "ladder rack": "ladder_rack_cable_runway",
+    "runway": "ladder_rack_cable_runway",
+    "riser": "riser_endpoint",
+    "junction box": "junction_box",
+    "pull box": "pull_box",
+    "camera": "camera_device",
+    "door contact": "door_contact_marker",
+    "card reader": "card_reader_device",
+    "request to exit": "request_to_exit_device",
+    "intercom": "intercom_endpoint",
+    "ground bar": "ground_bar",
+    "jack tag": "telecomm_jack_tag",
+    "data": "data_outlet",
+}
+
+
+def _norm(text: str) -> str:
+    return " ".join((text or "").lower().split())
+
+
+def derive_expected_families_from_packet_local_text(
+    *,
+    legend_texts: Iterable[str],
+    outlet_definition_texts: Iterable[str],
+    abbreviation_texts: Iterable[str],
+    page_titles: Iterable[str],
+    domain_default_families: Iterable[str],
+) -> List[str]:
+    joined = " | ".join(_norm(t) for t in list(legend_texts) + list(outlet_definition_texts) + list(abbreviation_texts) + list(page_titles))
+    families: Set[str] = set()
+    for kw, fam in KEYWORD_TO_FAMILY.items():
+        if kw in joined:
+            families.add(fam)
+
+    # Keep only packet-relevant domain families if any were found.
+    domain_defaults = set(domain_default_families)
+    if families:
+        return sorted(list(families & domain_defaults if domain_defaults else families))
+
+    # Fallback to a small domain prior if no specific evidence exists.
+    return sorted(list(domain_defaults))
