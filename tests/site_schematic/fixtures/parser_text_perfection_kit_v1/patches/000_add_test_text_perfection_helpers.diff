--- /dev/null
+++ b/tests/site_schematic/test_text_perfection_helpers.py
@@
+from orbitbrief_core.parser.site_schematic.note_clause_promoter import promote_note_clauses_from_blocks
+from orbitbrief_core.parser.site_schematic.locality_scope_closure import close_locality_scope_if_strong
+from orbitbrief_core.parser.site_schematic.global_note_guard import is_strong_global_note
+
+
+class DummyBlock:
+    def __init__(self, text, bbox):
+        self.text = text
+        self.bbox = bbox
+
+
+def test_note_promoter_emits_note_candidates():
+    blocks = [
+        DummyBlock("1. PROVIDE FIRESTOP SYSTEMS CONSISTING OF A MATERIAL...", [0,0,100,20]),
+        DummyBlock("ROOM 101", [0,40,40,50]),
+    ]
+    promoted = promote_note_clauses_from_blocks(sheet_type="schedule_sheet", layout_blocks=blocks, existing_note_count=0)
+    assert len(promoted) == 1
+    assert promoted[0]["reason"] == "note_like_block_promotion"
+
+
+def test_locality_scope_closure_promotes_when_strong():
+    note = {"scope_level": "unresolved", "scope_confidence": 0.2}
+    out = close_locality_scope_if_strong(
+        note,
+        same_detail_region=True,
+        same_column=True,
+        detail_cue_present=True,
+    )
+    assert out["scope_level"] == "detail_local"
+    assert out["metadata"]["locality_scope_closure"] is True
+
+
+def test_global_note_guard():
+    assert is_strong_global_note("GENERAL NOTES FOR TELECOMM ROOM")
+    assert not is_strong_global_note("Room 101")
