+++ b/src/orbitbrief_core/parser/site_schematic/note_clause_promoter.py
@@
+from __future__ import annotations
+
+import re
+from typing import Any, Dict, Iterable, List, Sequence
+
+
+NOTE_PATTERNS = [
+    re.compile(r"^\s*(?:\d+[\.\)]|[A-Z][\.\)]|[•\-])\s+"),
+    re.compile(r"\b(?:general note|keyed note|project requirements|notes)\b", re.I),
+]
+
+NOTE_SHEET_TYPES = {"schedule_sheet", "notes_spec", "legend_symbol", "riser_diagram"}
+
+
+def looks_like_note_text(text: str) -> bool:
+    text = (text or "").strip()
+    if len(text) < 20:
+        return False
+    return any(p.search(text) for p in NOTE_PATTERNS)
+
+
+def promote_note_clauses_from_blocks(
+    *,
+    sheet_type: str,
+    layout_blocks: Sequence[Any],
+    existing_note_count: int,
+) -> List[Dict[str, Any]]:
+    """
+    Deterministic fallback: if a page clearly has note-like text but emitted zero note clauses,
+    promote obvious note blocks into structured note candidates.
+    """
+    if sheet_type not in NOTE_SHEET_TYPES:
+        return []
+    if existing_note_count > 0:
+        return []
+
+    promoted: List[Dict[str, Any]] = []
+    for idx, block in enumerate(layout_blocks):
+        text = getattr(block, "text", None) if not isinstance(block, dict) else block.get("text")
+        bbox = getattr(block, "bbox", None) if not isinstance(block, dict) else block.get("bbox")
+        if not text or not bbox:
+            continue
+        if looks_like_note_text(text):
+            promoted.append({
+                "promoted_note_id": f"promoted_note:{idx}",
+                "text": text,
+                "bbox": bbox,
+                "reason": "note_like_block_promotion",
+                "source_mode": "deterministic_note_promoter_v1",
+            })
+    return promoted
