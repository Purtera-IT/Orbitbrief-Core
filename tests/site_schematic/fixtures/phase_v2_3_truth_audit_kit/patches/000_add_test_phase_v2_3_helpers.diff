--- /dev/null
+++ b/tests/site_schematic/test_phase_v2_3_helpers.py
@@
+from orbitbrief_core.parser.site_schematic.grounding_truth_audit import audit_packet_truth_signals
+from orbitbrief_core.parser.site_schematic.evidence_backed_flags import (
+    evidence_backed_connector_ok,
+    evidence_backed_room_assoc_ok,
+    evidence_backed_grounded_ok,
+)
+from orbitbrief_core.parser.site_schematic.hardpage_truth_enforcer import enforce_nonempty_required_hardpages
+from orbitbrief_core.parser.site_schematic.grounded_yield_sanity import check_yield_sanity
+
+
+def test_hardpage_truth_enforcer():
+    page_rows = [{"sheet_type": "legend_symbol"}, {"sheet_type": "riser_diagram"}]
+    req = enforce_nonempty_required_hardpages(page_rows=page_rows, schema_required_types=["legend_symbol", "riser_diagram", "floorplan_overall"])
+    assert req == ["legend_symbol", "riser_diagram"]
+
+
+def test_evidence_flags():
+    assert evidence_backed_connector_ok(connector_context_score=0.8, connector_candidate_count=1, leader_attachment_count=0)
+    assert evidence_backed_room_assoc_ok(room_device_association_score=0.8, near_room_label=True, same_region=False, leader_attached=False)
+    assert evidence_backed_grounded_ok(
+        grounding_state="grounded",
+        legend_match_score=0.9,
+        legend_text_association_score=0.8,
+        connector_context_score=0.7,
+        room_device_association_score=0.8,
+        page_type_compatibility=0.9,
+    )
+
+
+def test_truth_audit_detects_uniform():
+    result = audit_packet_truth_signals(
+        candidate_symbol_count=10,
+        grounded_symbol_count=10,
+        unresolved_symbol_count=0,
+        connector_topology_candidate_rate=0.0,
+        connector_grounding_quality_rate=1.0,
+        room_device_association_rate=1.0,
+        required_page_types=[],
+        satisfied_page_types=[],
+        grounded_rows=[{"grounding_state": "grounded", "connector_grounding_ok": True, "room_device_association_ok": True}] * 10,
+    )
+    assert result.suspicious_uniform_grounding or result.impossible_connector_success or result.impossible_room_assoc_success
+
+
+def test_yield_sanity():
+    s = check_yield_sanity(grounded_symbol_yield_rate=0.4, unresolved_symbol_ratio=0.5)
+    assert s.grounded_yield_ok is True
