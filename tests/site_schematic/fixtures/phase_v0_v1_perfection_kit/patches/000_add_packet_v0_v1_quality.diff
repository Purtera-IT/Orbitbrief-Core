--- /dev/null
+++ b/src/orbitbrief_core/parser/site_schematic/packet_v0_v1_quality.py
@@
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from typing import Dict, List
+
+
+@dataclass
+class PacketV0V1Summary:
+    packet_id: str
+    page_count: int
+    modality_counts: Dict[str, int] = field(default_factory=dict)
+    ambiguous_page_count: int = 0
+    primitive_count: int = 0
+    validated_primitive_count: int = 0
+    leader_candidate_count: int = 0
+    dimension_candidate_count: int = 0
+    modality_fail: bool = False
+    primitive_graph_fail: bool = False
+
+
+def summarize_packet_v0_v1(
+    *,
+    packet_id: str,
+    page_modality_rows: List[Dict[str, object]],
+    primitive_graph_rows: List[Dict[str, object]],
+) -> PacketV0V1Summary:
+    out = PacketV0V1Summary(packet_id=packet_id, page_count=len(page_modality_rows))
+    for row in page_modality_rows:
+        mod = str(row.get("modality", "unknown"))
+        out.modality_counts[mod] = out.modality_counts.get(mod, 0) + 1
+        if bool(row.get("ambiguous", False)):
+            out.ambiguous_page_count += 1
+    for row in primitive_graph_rows:
+        out.primitive_count += int(row.get("primitive_count", 0))
+        out.validated_primitive_count += int(row.get("validated_primitive_count", row.get("primitive_count", 0)))
+        out.leader_candidate_count += int(row.get("leader_candidate_count", 0))
+        out.dimension_candidate_count += int(row.get("dimension_candidate_count", 0))
+
+    if out.page_count == 0:
+        out.modality_fail = True
+    if out.primitive_count == 0:
+        out.primitive_graph_fail = True
+    return out
