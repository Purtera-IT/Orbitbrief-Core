{
  "phase": "phase_c_region_fidelity",
  "version": "2026-04-12.region_fidelity_v1",
  "perfect_targets": {
    "required_region_kind_coverage": 1.0,
    "region_bbox_presence_rate": 1.0,
    "region_hierarchy_completeness_rate": 1.0,
    "locality_provenance_rate": 1.0,
    "global_vs_local_note_separation_rate": 0.95,
    "detail_locality_reference_rate": 0.95,
    "multi_column_preservation_rate": 0.95,
    "table_region_reuse_rate": 0.95,
    "hybrid_page_overflatten_count": 0,
    "pseudo_page_fragmentation_error_count": 0,
    "silent_note_scope_conflict_count": 0,
    "untyped_region_count": 0
  },
  "hard_page_assertions": {
    "wireless_tc001_page1": {
      "required_region_kinds": [
        "title_block",
        "revision_block",
        "abbreviation_block",
        "drawing_index_block",
        "symbol_legend_block",
        "outlet_definition_block",
        "general_notes_block",
        "horizontal_cabling_notes_block",
        "junction_box_conduit_notes_block"
      ],
      "must_not": [
        "single_generic_page_blob"
      ],
      "table_anchor_dependency": [
        "abbreviation_block",
        "drawing_index_block",
        "symbol_legend_block",
        "outlet_definition_block"
      ]
    },
    "southern_t000_page1": {
      "required_region_kinds": [
        "title_block",
        "notes_spec_column",
        "drawing_index_block",
        "notes_section_block"
      ],
      "must_have_multi_column_preservation": true,
      "must_not": [
        "flattened_single_notes_blob"
      ]
    },
    "southern_t001_page2": {
      "required_region_kinds": [
        "responsibility_matrix_block",
        "structured_cabling_legend_block",
        "intrusion_legend_block",
        "access_intercom_legend_block",
        "cctv_legend_block",
        "legend_notes_block"
      ],
      "must_not": [
        "single_giant_legend_blob"
      ]
    },
    "southern_t700_page11": {
      "min_detail_frames": 8,
      "must_have_pseudo_pages": true,
      "must_not": [
        "global_note_attached_to_all_details"
      ]
    },
    "southern_t900_page12": {
      "required_region_kinds": [
        "equipment_room_plan_block",
        "rack_elevation_block",
        "grounding_riser_block",
        "embedded_schedule_block",
        "local_detail_note_block"
      ],
      "must_have_mixed_semantic_subregions": true,
      "must_not": [
        "equipment_room_flattened_to_single_region"
      ]
    },
    "southern_t901_page13": {
      "required_region_kinds": [
        "riser_body_block",
        "riser_callout_block",
        "detail_inset_block"
      ],
