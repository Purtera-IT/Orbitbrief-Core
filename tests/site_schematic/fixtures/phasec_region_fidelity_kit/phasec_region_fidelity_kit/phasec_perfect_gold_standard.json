        "detail_frame",
        "embedded_schedule_block",
        "local_detail_note_block"
      ],
      "must_have_embedded_schedule_detection": true
    },
    "southern_t906_page18": {
      "required_region_kinds": [
        "detail_frame",
        "pathway_support_block",
        "local_detail_note_block"
      ],
      "must_have_detail_locality": true
