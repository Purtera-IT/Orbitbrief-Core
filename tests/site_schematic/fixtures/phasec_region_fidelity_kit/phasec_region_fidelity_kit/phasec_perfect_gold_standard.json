  "phaseb_integration_requirements": {
    "universal_table_spine_must_remain_preserved": true,
    "region_objects_must_reference_source_table_ids_where_applicable": true,
    "table_backed_regions_must_not_fallback_to_generic_notes_when_table_kind_exists": true
  }
