+++ b/src/orbitbrief_core/parser/site_schematic/room_device_truth_audit.py
@@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Iterable, List
+
+
+@dataclass
+class RoomTruthAudit:
+    evidence_truth_ok: bool
+    score_distribution_ok: bool
+    reasons: List[str]
+
+
+def audit_room_device_truth(
+    *,
+    association_rate: float,
+    room_assoc_scores: Iterable[float],
+    near_room_label_hits: int,
+    same_region_hits: int,
+    leader_attached_hits: int,
+) -> RoomTruthAudit:
+    scores = list(room_assoc_scores)
+    reasons: List[str] = []
+    evidence_support = near_room_label_hits + same_region_hits + leader_attached_hits
+    score_distribution_ok = True
+    if scores:
+        unique_scores = len(set(round(float(s), 3) for s in scores))
+        if unique_scores <= 2 and association_rate >= 0.9:
+            score_distribution_ok = False
+            reasons.append("collapsed_room_assoc_score_distribution")
+    evidence_truth_ok = True
+    if association_rate >= 0.9 and evidence_support == 0:
+        evidence_truth_ok = False
+        reasons.append("high_room_assoc_without_evidence")
+    return RoomTruthAudit(evidence_truth_ok, score_distribution_ok, reasons)
