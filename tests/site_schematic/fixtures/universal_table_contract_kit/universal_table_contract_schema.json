{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Universal Parser-Level Table Contract",
  "type": "object",
  "required": [
    "tables",
    "semantic_lineage_refs",
    "contract_version"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "table_id",
          "packet_id",
          "pdf_id",
          "page_index",
          "sheet_number",
          "sheet_title",
          "region_id",
          "table_kind",
          "bbox",
          "source_mode",
          "provider",
          "confidence",
          "row_count",
          "column_count",
          "rows"
        ],
        "properties": {
          "table_id": {
            "type": "string"
          },
          "packet_id": {
            "type": "string"
          },
          "pdf_id": {
            "type": "string"
          },
          "page_index": {
            "type": "integer",
            "minimum": 1
          },
          "sheet_number": {
            "type": "string"
          },
          "sheet_title": {
            "type": "string"
          },
          "region_id": {
            "type": "string"
          },
          "detail_region_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "subregion_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "pseudo_page_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "table_kind": {
            "type": "string",
            "enum": [
              "drawing_index",
              "symbol_legend",
              "abbreviation_matrix",
              "outlet_definition",
              "schedule",
              "component_spec",
              "responsibility_matrix",
              "embedded_detail_schedule",
              "generic_grid",
              "manufacturer_part_table",
              "legend_notes"
            ]
          },
          "bbox": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4,
            "description": "[x0, y0, x1, y1] in page coordinates"
          },
          "source_mode": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "row_count": {
            "type": "integer",
            "minimum": 0
          },
          "column_count": {
            "type": "integer",
            "minimum": 0
          },
          "metadata": {
            "type": "object"
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "row_id",
                "table_id",
                "row_index",
                "bbox",
                "is_header",
                "cells",
                "raw_text_joined"
              ],
              "properties": {
                "row_id": {
                  "type": "string"
                },
                "table_id": {
                  "type": "string"
                },
                "row_index": {
                  "type": "integer",
                  "minimum": 0
                },
                "bbox": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "minItems": 4,
                  "maxItems": 4
                },
                "is_header": {
                  "type": "boolean"
                },
                "raw_text_joined": {
                  "type": "string"
                },
                "metadata": {
                  "type": "object"
                },
                "cells": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "cell_id",
                      "table_id",
                      "row_id",
                      "row_index",
                      "col_index",
                      "bbox",
                      "raw_text",
                      "normalized_text",
                      "rowspan",
                      "colspan",
                      "source_token_ids",
                      "confidence"
                    ],
                    "properties": {
                      "cell_id": {
                        "type": "string"
                      },
                      "table_id": {
                        "type": "string"
                      },
                      "row_id": {
                        "type": "string"
                      },
                      "row_index": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "col_index": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "bbox": {
                        "type": "array",
                        "items": {
                          "type": "number"
                        },
                        "minItems": 4,
                        "maxItems": 4
                      },
                      "raw_text": {
                        "type": "string"
                      },
                      "normalized_text": {
                        "type": "string"
                      },
                      "rowspan": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "colspan": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "source_token_ids": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "confidence": {
                        "type": "number"
                      },
                      "metadata": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "semantic_lineage_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "semantic_object_type",
          "semantic_object_id",
          "source_table_id",
          "source_row_id",
          "source_cell_ids"
        ],
        "properties": {
          "semantic_object_type": {
            "type": "string",
            "enum": [
              "legend_entry",
              "abbreviation_entry",
              "outlet_definition",
              "drawing_index_row",
              "schedule_row",
              "component_spec_row",
              "responsibility_matrix_row"
            ]
          },
          "semantic_object_id": {
            "type": "string"
          },
          "source_table_id": {
            "type": "string"
          },
          "source_row_id": {
            "type": "string"
          },
          "source_cell_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}