--- /dev/null
+++ b/tests/site_schematic/test_residual_fix_helpers.py
@@
+from orbitbrief_core.parser.site_schematic.residual_titleblock_profiles import score_residual_titleblock_families
+from orbitbrief_core.parser.site_schematic.region_bbox_completion import complete_region_bbox_from_children, ensure_locality_provenance
+from orbitbrief_core.parser.site_schematic.table_kind_aliases_residual import score_residual_holdout_table_aliases
+
+
+def test_residual_titleblock_profiles():
+    scores = score_residual_titleblock_families(
+        ["PROJECT REQUIREMENTS NOTES & SPECS", "DRAWING INDEX", "STRUCTURED CABLING SYSTEM / SECURITY"],
+        ["T000"]
+    )
+    assert scores.get("notes_spec", 0.0) > 0.0
+
+
+def test_region_bbox_completion():
+    region = {"region_id": "r1", "bbox": None, "metadata": {}}
+    children = [{"bbox": [0, 0, 10, 10]}, {"bbox": [5, 5, 20, 20]}]
+    assert complete_region_bbox_from_children(region, children)
+    assert region["bbox"] == (0.0, 0.0, 20.0, 20.0)
+
+
+def test_locality_provenance_completion():
+    obj = {"metadata": {}}
+    changed = ensure_locality_provenance(obj, parent_region_id="reg1", detail_region_id="det1")
+    assert changed
+    assert obj["metadata"]["locality_ids"]["region_id"] == "reg1"
+    assert obj["metadata"]["locality_ids"]["detail_region_id"] == "det1"
+
+
+def test_residual_table_aliases():
+    scores = score_residual_holdout_table_aliases(
+        "COMMUNICATIONS LEGEND",
+        ["SYMBOL", "DESCRIPTION", "COMMENTS"]
+    )
+    assert scores.get("symbol_legend", 0.0) > 0.0
