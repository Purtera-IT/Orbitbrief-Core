@@
+from orbitbrief_core.parser.site_schematic.vector_primitives import extract_vector_primitives_from_drawings
@@
 def build_site_schematic_page_observations(...):
@@
+    # Phase V1 starter: for vector-rich / hybrid pages, normalize PDF-native drawings when available.
+    # Keep additive and diagnostics-first.
+    try:
+        modality_by_page = model_registry.get("phase_v0_v1", {}).get("page_modality", [])
+        modality_lookup = {m["page_index"]: m["modality"] for m in modality_by_page}
+    except Exception:
+        modality_lookup = {}
+    for page_index, page_obs in enumerate(page_observations):
+        if modality_lookup.get(page_index) not in {"vector_rich", "hybrid"}:
+            continue
+        drawings = getattr(page_obs, "raw_pdf_drawings", None)
+        if drawings:
+            page_obs.vector_primitives = extract_vector_primitives_from_drawings(drawings, page_index=page_index)
