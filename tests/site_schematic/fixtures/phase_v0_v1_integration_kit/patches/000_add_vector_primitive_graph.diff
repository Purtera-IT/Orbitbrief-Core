+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from typing import Dict, Iterable, List, Tuple, Optional
+
+from orbitbrief_core.parser.site_schematic.vector_primitives import VectorPrimitive
+
+
+@dataclass
+class VectorJunction:
+    junction_id: str
+    x: float
+    y: float
+    primitive_ids: List[str] = field(default_factory=list)
+
+
+@dataclass
+class VectorPrimitiveGraph:
+    page_index: int
+    primitive_ids: List[str] = field(default_factory=list)
+    junctions: List[VectorJunction] = field(default_factory=list)
+    leader_candidate_ids: List[str] = field(default_factory=list)
+    connector_candidate_ids: List[str] = field(default_factory=list)
+    dimension_candidate_ids: List[str] = field(default_factory=list)
+    diagnostics: Dict[str, float] = field(default_factory=dict)
+
+
+def build_vector_primitive_graph(primitives: Iterable[VectorPrimitive], *, page_index: int) -> VectorPrimitiveGraph:
+    primitives = list(primitives)
+    g = VectorPrimitiveGraph(page_index=page_index)
+    g.primitive_ids = [p.primitive_id for p in primitives]
+
+    # extremely conservative starter logic:
+    # - lines with long aspect ratio become leader/connector candidates
+    # - boxes/curves present as geometry nodes
+    # - no fancy topology yet
+    leader_count = 0
+    connector_count = 0
+    dimension_count = 0
+    for p in primitives:
+        bbox = p.bbox
+        if bbox is None:
+            continue
+        w = max(0.0, bbox[2] - bbox[0])
+        h = max(0.0, bbox[3] - bbox[1])
+        long_ratio = max(w, h) / max(1.0, min(w, h) if min(w, h) > 0 else 1.0)
+        if p.primitive_kind == "line" and long_ratio >= 6:
+            g.leader_candidate_ids.append(p.primitive_id)
+            leader_count += 1
+        if p.primitive_kind in {"line", "polyline"} and long_ratio >= 3:
+            g.connector_candidate_ids.append(p.primitive_id)
+            connector_count += 1
+        if p.primitive_kind == "line" and 20 <= max(w, h) <= 300:
+            g.dimension_candidate_ids.append(p.primitive_id)
+            dimension_count += 1
+
+    g.diagnostics = {
+        "primitive_count": float(len(primitives)),
+        "leader_candidate_count": float(leader_count),
+        "connector_candidate_count": float(connector_count),
+        "dimension_candidate_count": float(dimension_count),
+    }
+    return g
