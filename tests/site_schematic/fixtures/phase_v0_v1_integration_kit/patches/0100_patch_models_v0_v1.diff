--- a/src/orbitbrief_core/parser/site_schematic/models.py
+++ b/src/orbitbrief_core/parser/site_schematic/models.py
@@
 from dataclasses import dataclass, field
 from typing import Any, Dict, List, Optional, Tuple
@@
+# Phase V0/V1 starter contracts
+@dataclass
+class SiteSchematicPageModalityDecision:
+    page_index: int
+    sheet_type: str
+    modality: str
+    confidence: float
+    scores: Dict[str, float] = field(default_factory=dict)
+    reasons: List[str] = field(default_factory=list)
+    diagnostics: Dict[str, float] = field(default_factory=dict)
+
+@dataclass
+class SiteSchematicVectorPrimitive:
+    primitive_id: str
+    primitive_kind: str
+    bbox: Optional[Tuple[float, float, float, float]]
+    page_index: int
+    confidence: float
+    metadata: Dict[str, Any] = field(default_factory=dict)
+
+@dataclass
+class SiteSchematicVectorPrimitiveGraph:
+    page_index: int
+    primitive_ids: List[str] = field(default_factory=list)
+    leader_candidate_ids: List[str] = field(default_factory=list)
+    connector_candidate_ids: List[str] = field(default_factory=list)
+    dimension_candidate_ids: List[str] = field(default_factory=list)
+    diagnostics: Dict[str, float] = field(default_factory=dict)
